# ─────────────────────────────────────────────────────────────────────────────
# Upcell Backend — Environment Variables
# Copy this file to .env (development) or .env.production (production).
# ─────────────────────────────────────────────────────────────────────────────

# ── App Environment ───────────────────────────────────────────────────────────
# "development" → connects to upcell_dev database
# "production"  → connects to upcell_prod database
NODE_ENV=development

# ── MongoDB Atlas (upcell-cluster) ────────────────────────────────────────────
# Development  → /upcell_dev
MONGODB_URL=mongodb+srv://<user>:<password>@upcell-cluster.6otlbdy.mongodb.net/upcell_dev?retryWrites=true&w=majority&appName=upcell-cluster

# Production   → /upcell_prod  (use this in .env.production)
# MONGODB_URL=mongodb+srv://<user>:<password>@upcell-cluster.6otlbdy.mongodb.net/upcell_prod?retryWrites=true&w=majority&appName=upcell-cluster

# ── Clerk Auth ────────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=your_clerk_secret_key

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend-domain.vercel.app
FRONTEND_ORIGINS=https://your-frontend-domain.vercel.app,https://your-custom-domain.com

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_KEY=your_resend_api_key
ADMIN_NOTIFICATION_EMAIL=admin@example.com
WHOLESALE_EMAIL_FROM="Upcell <wholesale@example.com>"
ORDER_EMAIL_FROM="Upcell <orders@example.com>"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001

# ── Stripe (optional) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
TEST_SECRET=your_test_stripe_secret_key
TEST_ENDPOINTSECRET=your_test_stripe_webhook_secret

# ── PayPal (optional) ─────────────────────────────────────────────────────────
ENVIRONMENT=PRODUCTION
PAYPAL_BASE_URL=https://api-m.paypal.com
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_RETURN_URL=https://your-frontend-domain.vercel.app/returnUrl
PAYPAL_CANCEL_URL=https://your-frontend-domain.vercel.app/cancelUrl
