# Copy this file to .env and fill in real values. Never commit .env itself.

NODE_ENV=development

# MongoDB Atlas connection string for THIS environment only.
# Dev branches should point at upcell_development, production (main branch / prod Render service)
# should point at upcell_production - never mix the two in one .env file.
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster-host>/<db-name>?retryWrites=true&w=majority

TEST_ENDPOINTSECRET=whsec_placeholder
RESEND_KEY=
PORT=5001
CLERK_SECRET_KEY=
FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173
ADMIN_NOTIFICATION_EMAIL=

# Single sender identity for all outbound mail (wholesale, order, trade-in) —
# must use a domain verified in Resend, e.g. "UpCell <notifications@mail.upcellit.com>"
EMAIL_FROM=
