# Copy this file to .env and fill in real values. Never commit .env itself.

NODE_ENV=development

# MongoDB Atlas connection string for THIS environment only.
# Dev branches should point at upcell_development, production (main branch / prod Render service)
# should point at upcell_production - never mix the two in one .env file.
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster-host>/<db-name>?retryWrites=true&w=majority

RESEND_KEY=
PORT=5001
CLERK_SECRET_KEY=
FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173
# Optional: comma-separated regex patterns for additional allowed CORS origins.
FRONTEND_ORIGIN_PATTERNS=
ADMIN_NOTIFICATION_EMAIL=

# Single sender identity for all outbound mail (wholesale, order, trade-in) —
# must use a domain verified in Resend, e.g. "UpCell <notifications@mail.upcellit.com>"
EMAIL_FROM=

# Stripe — use the *_SECRET/TEST_* pair matching this environment (live keys
# in production, test keys everywhere else). Get these from the Stripe dashboard.
STRIPE_SECRET_KEY=
TEST_SECRET=
STRIPE_WEBHOOK_SECRET=
TEST_ENDPOINTSECRET=whsec_placeholder

# PayPal — checkout.js only uses the live PAYPAL_* pair below when this is
# the exact string "PRODUCTION"; anything else (including unset) falls back
# to the TEST_PAYPAL_* pair. This is separate from NODE_ENV — double check
# it's actually set to PRODUCTION on the live Render service.
ENVIRONMENT=
PAYPAL_BASE_URL=https://api-m.paypal.com
TEST_PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
TEST_PAYPAL_CLIENT_ID=
TEST_PAYPAL_SECRET=
PAYPAL_RETURN_URL=
PAYPAL_CANCEL_URL=
# From the PayPal Developer Dashboard > your app > Webhooks, after adding a
# webhook subscribed to PAYMENT.CAPTURE.COMPLETED pointing at
# <your-backend-url>/checkout-customer/webhook. Needed to verify that a
# webhook POST actually came from PayPal (see checkout.controller.js).
# Sandbox and Live are separate webhooks with separate IDs in PayPal's
# dashboard — same TEST_*/live split as the other PAYPAL_* vars above.
PAYPAL_WEBHOOK_ID=
TEST_PAYPAL_WEBHOOK_ID=

# Cloudinary — used for product image uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
